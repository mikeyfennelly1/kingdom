{
  "packages": [
    "gcc@15.2.0",
    "clang-tools@21.1.8",
    "cmake@4.1.2",
    "ninja@1.13.1",
    "go-task@3.48.0",
    "openjdk@19.0.1+10",
    "plantuml@1.2026.2",
    "libpqxx",
    "pkg-config",
    "tmux@latest",
    "gum@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Development environment initialized'",
      "echo 'C++ compiler:' $(g++ --version | head -n 1)",
      "echo 'CMake:' $(cmake --version | head -n 1)",
      "echo 'Ninja:' $(ninja --version)",
      "echo 'Task:' $(task --version)"
    ]
  },
  "env": {
    "CXX":      "g++",
    "CC":       "gcc",
    "CXXFLAGS": "-std=c++20"
  }
}
