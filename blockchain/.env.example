# Ethereum wallet private key (without 0x prefix)
# Use a dedicated wallet for this project — never use a personal wallet
PRIVATE_KEY=your_private_key_here

# Sepolia RPC URL from Infura or Alchemy
# Infura: https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_project_id

# Set this after running: npx hardhat run scripts/deploy.js --network sepolia
CONTRACT_ADDRESS=
